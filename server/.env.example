# Server Configuration
PORT=4000
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGIN=https://giftguru.ai

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # requests per window

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gift-guru
MONGODB_USER=your-mongodb-user
MONGODB_PASSWORD=your-mongodb-password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=true
REDIS_CACHE_TTL=86400

# Instagram Graph API Configuration
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_API_VERSION=v18.0
INSTAGRAM_BASE_URL=https://graph.instagram.com

# Google Gemini API Configuration
GEMINI_API_KEY=GEMINI_API_KEY=AIzaSyDG1y1Sp5_jxgT4ZNfYsHRGJgRFxGYmDY
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_MS=10000

# Social Media Scraper Configuration
SCRAPER_MAX_POSTS=50
SCRAPER_CACHE_TTL=3600  # 1 hour
SCRAPER_RETRY_COUNT=3
SCRAPER_INITIAL_DELAY=500  # 500ms

# Session Configuration
SESSION_EXPIRY_HOURS=24 # Sessions expire after 24 hours of inactivity 